#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    combos {
        compatible = "zmk,combos";

        bt_clear {
            bindings = <&bt BT_CLR>;
            key-positions = <28 29>;
            layers = <2>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        layer_0 {
            bindings = <
&kp GRAVE         &kp Q       &kp W         &kp E     &kp R           &kp T        &kp Y           &kp U        &kp I     &kp O           &kp P           &kp BSPC
&kp TAB           &kp A       &kp S         &kp D     &kp F           &kp G        &kp H           &kp J        &kp K     &kp L           &kp MINUS       &kp ENTER
&kp LSHFT         &kp Z       &kp X         &kp C     &kp V           &kp B        &msc SCRL_UP    &lt 2 SPACE  &kp N     &kp M           &kp COMMA       &kp DOT          &kp UP_ARROW  &kp LS(INTERNATIONAL_1)
&kp LEFT_CONTROL  &kp ESCAPE  &kp LEFT_WIN  &kp LALT  &kp LEFT_BRACE  &lt 1 SPACE  &msc SCRL_DOWN  &lt 5 SPACE  &kp APOS  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW
            >;
        };

        layer_1 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans                &mkp LCLK  &mo 3             &mkp RCLK  &trans                 &trans
&trans  &trans  &trans  &trans  &trans  &trans  &kp RG(LEFT_BRACKET)  &mkp MB1   &mkp MB3          &mkp MB2   &kp RG(RIGHT_BRACKET)  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans                &trans     &kp LC(UP_ARROW)  &trans     &trans                 &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans                &trans     &trans            &trans     &trans                 &trans
            >;
        };

        layer_2 {
            bindings = <
&kp ESCAPE  &kp N1  &kp N2  &kp N3  &kp N4    &kp N5   &kp N6        &kp N7     &kp N8        &kp N9    &kp N0         &trans
&trans      &kp N6  &kp N7  &kp N8  &kp N9    &kp N0   &kp LS(PLUS)  &kp MINUS  &kp LS(STAR)  &kp FSLH  &kp LS(EQUAL)  &trans
&trans      &trans  &trans  &trans  &kp FSLH  &kp DOT  &trans        &trans     &trans        &trans    &trans         &trans  &trans  &trans
&trans      &trans  &trans  &trans  &trans    &trans   &trans        &trans     &trans        &trans    &trans         &trans
            >;
        };

        layer_4 {
            bindings = <
&kp QUESTION  &kp LS(EXCL)  &kp LS(N2)  &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &kp LS(N6)  &kp LS(N7)  &kp LS(N8)  &kp LS(N9)  &trans  &trans
&trans        &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans  &trans
&trans        &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans  &trans  &trans  &trans
&trans        &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans  &trans
            >;
        };

        layer_3 {
            bindings = <
&trans        &kp F1        &kp F2        &kp F3        &kp F4        &kp F5      &trans          &kp FSLH  &kp ASTRK  &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9
&trans        &kp F6        &kp F7        &kp F8        &kp F9        &kp F10     &trans          &trans    &kp MINUS  &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6
&trans        &kp F11       &kp F12       &out OUT_USB  &out OUT_BLE  &bt BT_NXT  &bt BT_CLR_ALL  &trans    &trans     &trans           &kp GRAVE        &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3
&bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &trans      &trans          &trans    &trans     &kp KP_NUMBER_0  &kp DOT          &kp EQUAL
            >;
        };

        layer_5 {
            bindings = <
&kp ESC  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &kp F12
&trans   &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans   &trans
&trans   &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans   &trans   &trans  &trans
&trans   &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans   &trans
            >;
        };

        layer_6 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
